# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bscout
POSTGRES_USER=bscout
POSTGRES_PASSWORD=bscout
DATABASE_URL=postgresql+asyncpg://bscout:bscout@localhost:5432/bscout

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# App
DEBUG=true
APP_NAME=BScout API
